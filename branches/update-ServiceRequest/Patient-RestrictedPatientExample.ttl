@prefix fhir: <http://hl7.org/fhir/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# - resource -------------------------------------------------------------------

<http://fhir.health.gov.lk/ips/Patient/RestrictedPatientExample> a fhir:Patient ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "RestrictedPatientExample"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "http://fhir.health.gov.lk/ips/StructureDefinition/patient-identity-cross-reference"^^xsd:anyURI ;
       fhir:link <http://fhir.health.gov.lk/ips/StructureDefinition/patient-identity-cross-reference>
     ] )
  ] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p style=\"border: 1px #661aff solid; background-color: #e6e6ff; padding: 10px;\"><b>Anonymous Patient</b> (no stated gender), DoB Unknown</p><hr/><table class=\"grid\"><tr><td style=\"background-color: #f3f5da\" title=\"Patient Links\">Links:</td><td colspan=\"3\"><ul><li>Please refer to: <a href=\"Patient-PatientExample.html\">Patient/PatientExample</a> &quot; SMITH&quot;</li></ul></td></tr></table></div>"
  ] ; # 
  fhir:link ( [
     fhir:other [
       fhir:link <http://fhir.health.gov.lk/ips/Patient/PatientExample> ;
       fhir:reference [ fhir:v "Patient/PatientExample" ]
     ] ;
     fhir:type [ fhir:v "refer" ]
  ] ) . # 

