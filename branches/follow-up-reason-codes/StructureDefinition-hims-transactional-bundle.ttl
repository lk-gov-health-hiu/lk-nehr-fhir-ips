         fhir:expression [ fhir:v "type = 'document' implies (identifier.system.exists() and identifier.value.exists())" ] ;
         fhir:xpath [ fhir:v "not(f:type/@value = 'document') or exists(f:identifier/f:system) or exists(f:identifier/f:value)" ] ;
