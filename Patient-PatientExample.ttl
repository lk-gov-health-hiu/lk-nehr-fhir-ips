# - resource -------------------------------------------------------------------

<http://fhir.health.gov.lk/ips/Patient/PatientExample> a fhir:Patient ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "PatientExample"] ; # 
  fhir:meta [
     fhir:profile ( [
